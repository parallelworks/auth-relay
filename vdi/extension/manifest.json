{
  "manifest_version": 3,
  "name": "PW YubiKey Relay",
  "version": "0.5.0",
  "description": "Forwards WebAuthn (navigator.credentials) calls to a YubiKey relay agent on the user's laptop.",
  "key": "",
  "permissions": ["webAuthenticationProxy", "nativeMessaging", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "minimum_chrome_version": "115"
}
