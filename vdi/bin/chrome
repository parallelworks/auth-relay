#!/usr/bin/env bash
# Launches the portable Chrome the relay was built around.
# Search order (first hit wins):
#   1. $PW_CHROME_BIN if set and executable
#   2. <repo>/chrome-portable/opt/google/chrome/google-chrome
#   3. /usr/bin/google-chrome  (system install, if present)
#   4. chromium / chromium-browser on PATH
#
# Pass any extra Chrome flags after this script's name; they go straight through.

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$HERE/.." && pwd)"

find_chrome() {
  if [[ -n "${PW_CHROME_BIN:-}" && -x "${PW_CHROME_BIN}" ]]; then
    printf '%s' "$PW_CHROME_BIN"
    return 0
  fi
  local candidates=(
    "$REPO_ROOT/chrome-portable/opt/google/chrome/google-chrome"
    "/usr/bin/google-chrome"
    "/usr/bin/google-chrome-stable"
  )
  for c in "${candidates[@]}"; do
    [[ -x "$c" ]] && { printf '%s' "$c"; return 0; }
  done
  for c in chromium chromium-browser; do
    if command -v "$c" >/dev/null 2>&1; then
      command -v "$c"
      return 0
    fi
  done
  return 1
}

CHROME="$(find_chrome)" || {
  cat >&2 <<EOF
no Chrome binary found.

Set PW_CHROME_BIN to your install, or run:
    bash $REPO_ROOT/vdi/install-chrome.sh [<install-prefix>]
EOF
  exit 1
}

# We DO NOT set --user-data-dir. Earlier deployment caught that Chrome
# (148+) looks for native-messaging-host manifests under
# <user-data-dir>/NativeMessagingHosts/, NOT at the standard
# ~/.config/google-chrome/NativeMessagingHosts/ path that bootstrap.sh
# writes to. Forcing the default profile keeps the lookup wired up.
#
# Redirect Chrome's stderr/stdout to a log file. Chrome dumps a *lot* of
# debug info to stderr by default; left attached to a terminal that
# launched the wrapper with `&`, it makes the shell unusable. The log
# is at /tmp/pw-chrome.log if you need to inspect it.
LOG="${PW_CHROME_LOG:-/tmp/pw-chrome-$(id -un).log}"

# NOAA HPC login nodes (Gaea, Hera, ...) ship with ulimit -s = 1 GiB
# (1048576 KiB), which Chrome inherits. Every pthread_create reserves
# a stack mapping of that size; Chrome opens hundreds of threads and
# quickly exhausts /proc/sys/vm/max_map_count or virtual address space,
# yielding cascading "pthread_create: Resource temporarily unavailable"
# crashpad loops. Pin the stack to a sensible Linux default (8 MiB).
# The current-shell soft limit is what new processes inherit.
ulimit -Ss 8192 2>/dev/null || true

exec "$CHROME" "$@" </dev/null >>"$LOG" 2>&1
