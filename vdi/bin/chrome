#!/usr/bin/env bash
# Launches the portable Chrome the relay was built around.
# Search order (first hit wins):
#   1. $PW_CHROME_BIN if set and executable
#   2. <repo>/chrome-portable/opt/google/chrome/google-chrome
#   3. /usr/bin/google-chrome  (system install, if present)
#   4. chromium / chromium-browser on PATH
#
# Pass any extra Chrome flags after this script's name; they go straight through.

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
# This script lives at <repo>/vdi/bin/chrome — two parents up to the repo.
REPO_ROOT="$(cd "$HERE/../.." && pwd)"

find_chrome() {
  if [[ -n "${PW_CHROME_BIN:-}" && -x "${PW_CHROME_BIN}" ]]; then
    printf '%s' "$PW_CHROME_BIN"
    return 0
  fi
  local candidates=(
    "$REPO_ROOT/chrome-portable/opt/google/chrome/google-chrome"
    "/usr/bin/google-chrome"
    "/usr/bin/google-chrome-stable"
  )
  for c in "${candidates[@]}"; do
    [[ -x "$c" ]] && { printf '%s' "$c"; return 0; }
  done
  for c in chromium chromium-browser; do
    if command -v "$c" >/dev/null 2>&1; then
      command -v "$c"
      return 0
    fi
  done
  return 1
}

CHROME="$(find_chrome)" || {
  cat >&2 <<EOF
no Chrome binary found.

Set PW_CHROME_BIN to your install, or run:
    bash ${REPO_ROOT}/vdi/install-chrome.sh [<install-prefix>]
EOF
  exit 1
}

# We USE a dedicated user-data-dir for the relay. Chrome 148+ has two
# constraints that together force this:
#   1. NMH manifests are looked up under <user-data-dir>/NativeMessagingHosts/
#      when --user-data-dir is explicitly set.
#   2. --remote-debugging-port is silently disabled if --user-data-dir
#      is NOT set ("DevTools remote debugging requires a non-default
#      data directory" appears in the log). install-extension.py's
#      CDP-driven Extensions.loadUnpacked needs the debug port, so we
#      have to pass --user-data-dir.
# bootstrap.sh writes the NMH manifest into this dir's
# NativeMessagingHosts/ so #1 resolves correctly.
PW_CHROME_USER_DATA_DIR="${PW_CHROME_USER_DATA_DIR:-$HOME/.config/google-chrome-pwrelay}"
mkdir -p "$PW_CHROME_USER_DATA_DIR" 2>/dev/null || true
#
# Redirect Chrome's stderr/stdout to a log file. Chrome dumps a *lot* of
# debug info to stderr by default; left attached to a terminal that
# launched the wrapper with `&`, it makes the shell unusable. The log
# is at /tmp/pw-chrome.log if you need to inspect it.
LOG="${PW_CHROME_LOG:-/tmp/pw-chrome-$(id -un).log}"

# If DISPLAY isn't set (e.g., we were invoked from a pw ssh shell with no
# X forwarding), discover the user's running VNC server's display + auth
# file. Lets `pw ssh resource '~/auth-relay/vdi/bin/chrome &'` Just Work
# from a laptop terminal — Chrome pops into the VDI desktop the user
# already has open.
if [[ -z "${DISPLAY:-}" ]]; then
  vnc_argv=$(ps -u "$(whoami)" -o args= 2>/dev/null \
              | grep -E '/(Xvnc|Xkasmvnc|Xtigervnc|Xvfb)( |$)' \
              | head -1)
  if [[ -n "$vnc_argv" ]]; then
    disp=$(printf ' %s ' "$vnc_argv" | grep -oE ' :[0-9]+ ' | head -1 | tr -d ' ')
    xauth=$(printf '%s' "$vnc_argv" | sed -nE 's/.*-auth +([^ ]+).*/\1/p' | head -1)
    if [[ -n "$disp" ]]; then
      export DISPLAY="$disp"
      [[ -n "$xauth" ]] && export XAUTHORITY="$xauth"
      echo "[chrome] auto-detected VDI: DISPLAY=$DISPLAY XAUTHORITY=${XAUTHORITY:-(none)}" >&2
    fi
  fi
fi

# NOAA HPC login nodes (Gaea, Hera, ...) ship with ulimit -s = 1 GiB
# (1048576 KiB), which Chrome inherits. Every pthread_create reserves
# a stack mapping of that size; Chrome opens hundreds of threads and
# quickly exhausts /proc/sys/vm/max_map_count or virtual address space,
# yielding cascading "pthread_create: Resource temporarily unavailable"
# crashpad loops. Pin the stack to a sensible Linux default (8 MiB).
# The current-shell soft limit is what new processes inherit.
ulimit -Ss 8192 2>/dev/null || true

# Suppress Chrome's first-run UI gates that block headless / unattended
# automation. Without these flags, the very first launch of a fresh
# profile blocks on a series of dialogs:
#   - "Make Chrome your default browser?"        --no-default-browser-check
#   - "Welcome to Chrome" first-run UI           --no-first-run
#   - Search-engine-choice modal (Chrome 122+)   --disable-search-engine-choice-screen
#   - gnome-keyring / kwallet "create password"  --password-store=basic
# The keyring one bit us on Rocky Linux 9 inside a VDI: Chrome's secret-
# service request pops a modal that steals focus and silently blocks
# install-extension.py's CDP Extensions.loadUnpacked.
exec "$CHROME" \
    --user-data-dir="$PW_CHROME_USER_DATA_DIR" \
    --no-first-run \
    --no-default-browser-check \
    --disable-default-apps \
    --disable-search-engine-choice-screen \
    --password-store=basic \
    "$@" </dev/null >>"$LOG" 2>&1
