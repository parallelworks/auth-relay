#!/usr/bin/env bash
# pwrelay — laptop-side CLI for the PW YubiKey Relay.
#
# One command brings up the agent + pw ssh -R tunnel to your PW resource.
# Foreground; Ctrl+C cleans up. Logs go to stderr (tee'd from agent.py).
#
# Usage:
#   ./pwrelay setup                    one-time: deps + venv + key check
#   ./pwrelay up <resource>            start agent + tunnel; stays foreground
#   ./pwrelay status                   show what (if anything) is running
#   ./pwrelay down                     stop our agent/tunnel; tell remote
#                                      to drop our tunnel keepalive too
#   ./pwrelay doctor [<resource>]      print local + remote state for diag
#   ./pwrelay reset  [<resource>]      kill everything *we own* on both ends
#                                      (never touches pw agent)
#
# Examples:
#   ./pwrelay up workspace
#   ./pwrelay up gaeac5
#   ./pwrelay doctor gaeac5            when something looks stuck
#   ./pwrelay reset  gaeac5            nuclear cleanup, both ends

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
VENV="$HERE/.venv"
PORT="${PW_RELAY_PORT:-7777}"
PID_AGENT="/tmp/pwrelay-agent.pid"
PID_TUNNEL="/tmp/pwrelay-tunnel.pid"
PID_PORT="/tmp/pwrelay-port"        # chosen port this session
PID_SESSION="/tmp/pwrelay-session"  # unique session-id marker for remote pkill
PID_RESOURCE="/tmp/pwrelay-resource"
LOG_AGENT="/tmp/pwrelay-agent.log"
LOG_TUNNEL="/tmp/pwrelay-tunnel.log"

color()  { tput setaf "$1" 2>/dev/null || true; }
reset()  { tput sgr0 2>/dev/null || true; }
say()    { printf '%s%s%s\n' "$(color 6)[pwrelay]$(reset) " "$*" ""; }
err()    { printf '%s%s%s\n' "$(color 1)[pwrelay error]$(reset) " "$*" "" >&2; }
ok()     { printf '%s%s%s\n' "$(color 2)[pwrelay ok]$(reset) " "$*" ""; }

die() { err "$*"; exit 1; }

need_cmd() { command -v "$1" >/dev/null 2>&1 || die "$1 not on PATH"; }

# ---- setup -----------------------------------------------------------------

cmd_setup() {
  need_cmd python3
  need_cmd pw
  need_cmd ssh

  # Match the user's pw auth state.
  pw auth whoami >/dev/null 2>&1 || die "pw CLI not authenticated. Run: pw auth login"

  [[ -f "$HOME/.ssh/pwcli" ]] || die "~/.ssh/pwcli missing. Run: pw auth login"

  if [[ ! -d "$VENV" ]]; then
    say "creating venv at $VENV"
    python3 -m venv "$VENV"
  fi

  # shellcheck source=/dev/null
  source "$VENV/bin/activate"

  if ! python3 -c 'import fido2' >/dev/null 2>&1; then
    say "installing python-fido2 into venv"
    python3 -m pip install --upgrade pip >/dev/null
    python3 -m pip install fido2 >/dev/null
  fi

  # Probe the key — non-fatal if missing, but warn loudly.
  if python3 -c 'from fido2.hid import CtapHidDevice; assert list(CtapHidDevice.list_devices())' 2>/dev/null; then
    ok "YubiKey detected"
  else
    err "no FIDO2 USB device found right now (plug it in before \`pwrelay up\`)"
  fi

  ok "setup complete"
}

# ---- runtime helpers -------------------------------------------------------

ensure_venv() {
  [[ -d "$VENV" ]] || die "venv not found. Run: ./pwrelay setup"
  # shellcheck source=/dev/null
  source "$VENV/bin/activate"
}

is_running() {
  local pid_file="$1"
  [[ -f "$pid_file" ]] || return 1
  local pid; pid=$(cat "$pid_file" 2>/dev/null || true)
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

stop_pid() {
  local pid_file="$1" name="$2"
  if is_running "$pid_file"; then
    local pid; pid=$(cat "$pid_file")
    say "stopping $name (pid $pid)"
    # Kill children first so an ssh child of the supervisor loop doesn't
    # outlive the loop and keep holding the remote port for the next run.
    local kids; kids=$(pgrep -P "$pid" 2>/dev/null || true)
    kill "$pid" 2>/dev/null || true
    [[ -n "$kids" ]] && kill $kids 2>/dev/null || true
    for _ in 1 2 3 4; do kill -0 "$pid" 2>/dev/null || break; sleep 0.5; done
    kill -9 "$pid" 2>/dev/null || true
    [[ -n "$kids" ]] && kill -9 $kids 2>/dev/null || true
  fi
  rm -f "$pid_file"
}

resolve_resource() {
  # Accept short, full, or pw:// forms. Default to "workspace".
  local r="${1:-workspace}"
  printf '%s' "$r"
}

resource_user() {
  # The user portion for the inner ssh. pw CLI itself runs as the caller's
  # account; the SSH inside the proxy needs the resource's owner. We default
  # to `pw auth whoami` which is the caller; that works for the user's own
  # resources. Override with PW_RESOURCE_USER=<name> if connecting to a
  # resource owned by someone else who's granted you access.
  if [[ -n "${PW_RESOURCE_USER:-}" ]]; then
    printf '%s' "$PW_RESOURCE_USER"
    return
  fi
  pw auth whoami 2>/dev/null
}

# ---- up --------------------------------------------------------------------

cmd_up() {
  local resource; resource=$(resolve_resource "${1:-}")
  ensure_venv

  if is_running "$PID_AGENT"; then
    say "agent already running (pid $(cat "$PID_AGENT")). Use \`pwrelay down\` to stop."
    exit 1
  fi

  # Pick an unused port for this session. Start at PORT (default 7777) and
  # walk up to PORT+7. The pw-agent on the cluster caches forward state
  # across sessions — if a prior pwrelay's forward isn't fully released
  # we just use the next port instead of fighting for the same one.
  local rs_user; rs_user=$(resource_user)
  say "checking which port is free on remote $resource ..."
  local chosen_port=""
  local cand
  for cand in "$PORT" $((PORT+1)) $((PORT+2)) $((PORT+3)) $((PORT+4)) $((PORT+5)) $((PORT+6)) $((PORT+7)); do
    if pw ssh "$resource" "ss -tlnp 2>/dev/null | grep -q ':${cand} ' && echo BUSY || echo FREE" 2>/dev/null | grep -q FREE; then
      chosen_port="$cand"
      break
    fi
  done
  if [[ -z "$chosen_port" ]]; then
    err "no free port in ${PORT}..$((PORT+7)) on $resource. Run \`pwrelay doctor $resource\`."
    exit 1
  fi
  if [[ "$chosen_port" != "$PORT" ]]; then
    say "port ${PORT} on remote is busy (likely pw-agent caching a prior forward); using ${chosen_port}"
  fi
  echo "$chosen_port" > "$PID_PORT"
  echo "$resource" > "$PID_RESOURCE"

  # Drop the chosen port on the remote so the NMH wrapper can read it.
  # This way the in-VDI Chrome's NMH always finds the live port without
  # touching its already-running profile.
  local remote_port_file="/tmp/pw-relay-port-${rs_user}"
  pw ssh "$resource" "echo ${chosen_port} > ${remote_port_file}" 2>/dev/null || true

  # Unique marker so cmd_down can identify *our* sleep on the remote and
  # not collide with another pwrelay instance the user may have running.
  local session_id; session_id="pwrelay-$(date +%s)-$$"
  echo "$session_id" > "$PID_SESSION"

  # Agent.
  say "starting agent on 127.0.0.1:${chosen_port}"
  python3 "$HERE/laptop/agent.py" --port "$chosen_port" >"$LOG_AGENT" 2>&1 &
  echo $! > "$PID_AGENT"
  sleep 0.6
  if ! is_running "$PID_AGENT"; then
    err "agent failed to start; tail $LOG_AGENT"
    sed -n '1,20p' "$LOG_AGENT" >&2 || true
    exit 1
  fi
  ok "agent listening on 127.0.0.1:${chosen_port}"

  # Tunnel — wrapped in a supervisor loop so the connection respawns if the
  # cluster drops the session (some HPC clusters idle-time-out after about
  # an hour even with ServerAliveInterval set). The supervisor itself
  # is what we put in PID_TUNNEL; killing it exits the loop cleanly.
  # The remote bash uses `exec -a` to rename the sleep process so cmd_down
  # can pkill *only our* keepalive without touching anyone else's.
  say "opening reverse tunnel via pw ssh to $resource ($rs_user@$resource) [auto-reconnect, port ${chosen_port}]"
  : >"$LOG_TUNNEL"
  (
    while true; do
      ssh -i "$HOME/.ssh/pwcli" \
          -o ProxyCommand="pw ssh --proxy-command %h" \
          -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
          -o ServerAliveInterval=30 -o ServerAliveCountMax=3 \
          -o TCPKeepAlive=yes -o ExitOnForwardFailure=yes \
          -R "${chosen_port}:127.0.0.1:${chosen_port}" \
          "${rs_user}@${resource}" \
          "echo \"[remote] tunnel-up on \$(hostname); pid=\$\$ marker=${session_id}\"; exec -a \"${session_id}\" sleep 86400"
      rc=$?
      if grep -qE "Permission denied|remote port forwarding failed" "$LOG_TUNNEL" 2>/dev/null; then
        echo "[supervisor] terminal failure (rc=$rc); not retrying" >>"$LOG_TUNNEL"
        exit "$rc"
      fi
      echo "[supervisor] ssh exited rc=$rc — reconnecting in 3s" >>"$LOG_TUNNEL"
      sleep 3
    done
  ) >>"$LOG_TUNNEL" 2>&1 &
  echo $! > "$PID_TUNNEL"

  # Wait for the tunnel-up line.
  local waited=0
  while ! grep -q "tunnel-up on" "$LOG_TUNNEL" 2>/dev/null; do
    sleep 0.5
    waited=$((waited + 1))
    if [[ $waited -gt 30 ]]; then
      err "tunnel didn't come up in 15s; tail $LOG_TUNNEL"
      sed -n '1,30p' "$LOG_TUNNEL" >&2 || true
      cmd_down >/dev/null 2>&1 || true
      exit 1
    fi
    if ! is_running "$PID_TUNNEL"; then
      if grep -q "remote port forwarding failed for listen port" "$LOG_TUNNEL" 2>/dev/null; then
        err "every port in ${PORT}..$((PORT+7)) was rejected on $resource."
        err "the pw-agent on the cluster may be holding stale forward state across a wide range."
        err "try \`pwrelay doctor $resource\` for a state dump, or open a fresh pw context."
        err "DO NOT kill any process named 'pw agent' on the remote — that's your cluster's per-user daemon."
      elif grep -q "Permission denied (publickey)" "$LOG_TUNNEL" 2>/dev/null; then
        err "ssh public-key auth refused. \`pw auth login\` to refresh, then retry."
      else
        err "tunnel exited; tail $LOG_TUNNEL"
        sed -n '1,30p' "$LOG_TUNNEL" >&2 || true
      fi
      cmd_down >/dev/null 2>&1 || true
      exit 1
    fi
  done
  local rhost; rhost=$(grep -m1 "tunnel-up on" "$LOG_TUNNEL" | sed 's/.*tunnel-up on //; s/;.*//')
  ok "tunnel up to $rhost — port ${chosen_port} on remote -> agent on this laptop"

  cat <<EOF

────────────────────────────────────────────────────────────────────
 Relay live. On the VDI side (one-time per session):
   bash <path-to-this-repo>/vdi/bootstrap.sh   (or just open Chrome
   if extension and NMH manifest are already installed)
 Then open http://localhost:8080/test.html in the VDI Chrome.
 Ctrl+C here tears down the agent and tunnel cleanly.
────────────────────────────────────────────────────────────────────

EOF

  # Forward signals; tail the agent log so the user sees activity.
  trap 'echo; cmd_down; exit 0' INT TERM
  tail -F "$LOG_AGENT" 2>/dev/null
}

# ---- down ------------------------------------------------------------------

cmd_down() {
  # Best-effort: tell the remote to kill *our* marked sleep first, so the
  # pw agent releases the port quickly instead of caching the forward.
  if [[ -f "$PID_SESSION" && -f "$PID_RESOURCE" ]]; then
    local sid res
    sid=$(cat "$PID_SESSION" 2>/dev/null || true)
    res=$(cat "$PID_RESOURCE" 2>/dev/null || true)
    if [[ -n "$sid" && -n "$res" ]]; then
      say "asking remote ($res) to release our session marker '${sid}'"
      pw ssh "$res" "pkill -u \$(whoami) -f \"${sid}\" 2>/dev/null; true" >/dev/null 2>&1 || true
    fi
  fi
  stop_pid "$PID_TUNNEL" "ssh tunnel"
  stop_pid "$PID_AGENT" "agent"
  rm -f "$PID_PORT" "$PID_SESSION" "$PID_RESOURCE"
  ok "relay stopped"
}

# ---- doctor ----------------------------------------------------------------

cmd_doctor() {
  local resource; resource=$(resolve_resource "${1:-}")
  say "=== local (this laptop) ==="
  cmd_status
  echo "  port file : $(cat "$PID_PORT" 2>/dev/null || echo '(none)')"
  echo "  session   : $(cat "$PID_SESSION" 2>/dev/null || echo '(none)')"
  echo "  resource  : $(cat "$PID_RESOURCE" 2>/dev/null || echo '(none)')"
  echo
  echo "  agent log tail:"
  tail -3 "$LOG_AGENT" 2>/dev/null | sed 's/^/    /'
  echo "  tunnel log tail:"
  tail -5 "$LOG_TUNNEL" 2>/dev/null | sed 's/^/    /'
  echo
  say "=== remote ($resource) ==="
  pw ssh "$resource" '
    echo "  hostname  : $(hostname)"
    echo "  whoami    : $(whoami)"
    echo "  ports 7777..7785 (listening):"
    ss -tlnp 2>/dev/null | awk "/:777[0-9] /{ printf \"    %s  %s\n\", \$4, \$6 }"
    echo "  my pwrelay-tagged sleeps (safe to kill via pwrelay reset):"
    ps -u "$(whoami)" -o pid,comm 2>/dev/null | awk "/pwrelay-/{ printf \"    pid=%s argv0=%s\n\", \$1, \$2 }"
    echo "  pw agent (DO NOT KILL):"
    pgrep -afu "$(whoami)" "pw agent" 2>/dev/null | sed "s/^/    /"
    echo "  port hint file:"
    cat "/tmp/pw-relay-port-$(whoami)" 2>/dev/null | sed "s/^/    /"
  ' 2>&1 | head -40
}

# ---- reset -----------------------------------------------------------------

cmd_reset() {
  local resource
  resource=$(cat "$PID_RESOURCE" 2>/dev/null || resolve_resource "${1:-}")
  say "resetting local pwrelay state (does NOT touch any pw agent)"
  cmd_down >/dev/null 2>&1 || true
  pkill -f "$HERE/laptop/agent.py" 2>/dev/null || true
  if [[ -n "$resource" ]]; then
    say "asking $resource to kill ALL pwrelay-tagged sleeps for this user"
    pw ssh "$resource" 'pkill -u $(whoami) -f "pwrelay-" 2>/dev/null; rm -f /tmp/pw-relay-port-$(whoami); true' >/dev/null 2>&1 || true
  fi
  ok "reset complete"
}

# ---- status ----------------------------------------------------------------

cmd_status() {
  if is_running "$PID_AGENT"; then
    ok "agent: running (pid $(cat "$PID_AGENT"))"
  else
    say "agent: not running"
  fi
  if is_running "$PID_TUNNEL"; then
    ok "tunnel: running (pid $(cat "$PID_TUNNEL"))"
    grep "tunnel-up on" "$LOG_TUNNEL" 2>/dev/null | tail -1
  else
    say "tunnel: not running"
  fi
}

# ---- entry -----------------------------------------------------------------

case "${1:-}" in
  setup)    shift; cmd_setup "$@" ;;
  up)       shift; cmd_up "$@" ;;
  down|stop) cmd_down ;;
  status)   cmd_status ;;
  doctor)   shift; cmd_doctor "$@" ;;
  reset)    shift; cmd_reset "$@" ;;
  ""|-h|--help|help)
    sed -n '2,17p' "$0" ;;
  *)
    err "unknown subcommand: $1"
    sed -n '2,17p' "$0" >&2
    exit 1
    ;;
esac
